    {
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_BEEGFS_MON_INFLUXDB}"
      },
      "description": "Top clients by current watched inode count on the selected meta. Last value within the time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "center",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 100000
              },
              {
                "color": "red",
                "value": 1000000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Watched Inodes"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Watched Inodes"
          }
        ]
      },
      "pluginVersion": "9.3.0",
      "targets": [
        {
          "alias": "Watched Inodes",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_BEEGFS_MON_INFLUXDB}"
          },
          "groupBy": [],
          "measurement": "invalWatchPerClient",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "from(bucket: \"${bucket}\")  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)  |> filter(fn: (r) =>    r.nodeNumID == \"${metaID}\" and    r._measurement == \"invalWatchPerClient\" and    r._field == \"watchedInodeCount\")  |> group(columns: [\"clientId\"])  |> last()  |> group()  |> keep(columns: [\"clientId\", \"_value\"])  |> rename(columns: {_value: \"Watched Inodes\"})  |> sort(columns: [\"Watched Inodes\"], desc: true)  |> limit(n: 50)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "table"
        }
      ],
      "title": "Top Clients by Watched Inodes (meta ${metaID})",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "Watched Inodes": 1,
              "clientId": 0
            },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_BEEGFS_MON_INFLUXDB}"
      },
      "description": "Watched inode count per client over time. Stacked to show total watched inodes by client.",
