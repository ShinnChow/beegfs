          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_BEEGFS_MON_INFLUXDB}"
          },
          "groupBy": [],
          "measurement": "invalWatchPerClient",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "from(bucket: \"${bucket}\")  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)  |> filter(fn: (r) =>    r.nodeNumID == \"${metaID}\" and    r._measurement == \"invalWatchPerClient\" and    r._field == \"numInvalidations\" and    contains(value: r.clientId, set: ${clientId:json}))  |> group(columns: [\"clientId\"])  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)  |> derivative(unit: 1s, nonNegative: true)  |> rename(columns: {_value: \"invalidations/s\"})",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
