              }
            ]
          ],
          "tags": [
            {
              "key": "nodeNumID",
              "operator": "=~",
              "value": "/^$metaID$/"
            }
          ]
        }
      ],
      "title": "Top Clients by Watched Inodes (meta $metaID)",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
