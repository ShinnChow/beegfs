      "targets": [
        {
          "alias": "$tag_clientId",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_BEEGFS_MON_INFLUXDB}"
          },
          "groupBy": [
            {
              "params": [
                "clientId"
              ],
              "type": "tag"
            }
          ],
          "measurement": "invalWatchPerClient",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT last(\"watchedInodeCount\") FROM \"invalWatchPerClient\" WHERE \"nodeNumID\" =~ /^$metaID$/ AND $timeFilter GROUP BY \"clientId\"",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "table",
          "select": [
            [
              {
                "params": [
